# .env.example — template for local environment variables.
#
# Usage:
#     cp .env.example .env && source .env
#
# All entries are commented out. Uncomment and fill in the values you
# need. Never commit a populated `.env` (it should be in .gitignore).

# ---------------------------------------------------------------------
# MLflow tracking
# ---------------------------------------------------------------------
# URI of your MLflow tracking server. Defaults to a local server.
#MLFLOW_TRACKING_URI=http://localhost:5000

# ---------------------------------------------------------------------
# Weights & Biases
# ---------------------------------------------------------------------
# SECURITY: never commit your real W&B API key. Treat it like a password.
# Prefer `wandb login` (stores in ~/.netrc) over setting this in shell.
#WANDB_API_KEY=

# Project and entity (team/user) used by wandb.init(). `WANDB_PROJECT`
# falls back to "wafer-defect" when unset.
#WANDB_PROJECT=wafer-defect
#WANDB_ENTITY=

# ---------------------------------------------------------------------
# Kaggle API (for dataset downloads)
# ---------------------------------------------------------------------
# For local development, prefer ~/.kaggle/kaggle.json (chmod 600) over
# setting these env vars. These are provided for CI/containers where
# mounting a config file is inconvenient.
#KAGGLE_USERNAME=
#KAGGLE_KEY=

# ---------------------------------------------------------------------
# Logging / run identification
# ---------------------------------------------------------------------
# Manual run-id override. When unset, logging_setup.setup_logging()
# generates a fresh uuid4 hex per process.
#WAFER_RUN_ID=

# Root log level (DEBUG, INFO, WARNING, ERROR). Default INFO.
#WAFER_LOG_LEVEL=INFO

# Log output format: `json` for structured aggregation, `human` for
# readable console output. Default human.
#WAFER_LOG_FORMAT=human
